APP_NAME=Violyt Backend
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-this-secret-key-to-32-plus-characters
SOCIAL_ENCRYPTION_KEY=
DATABASE_URL=postgresql+asyncpg://violyt:violyt@localhost:5432/violyt
ALEMBIC_DATABASE_URL=postgresql+psycopg://violyt:violyt@localhost:5432/violyt
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_MINUTES=10080
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
RESEARCH_PROVIDER=anthropic
TEXT_PROVIDER=openai
IMAGE_PROVIDER=openai
FALLBACK_TEXT_PROVIDER=openai
FALLBACK_IMAGE_PROVIDER=mock
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BASE_PATH=./storage
GENERATED_ASSETS_BASE_URL=http://localhost:8000/storage
FRONTEND_BASE_URL=http://localhost:3000
VECTOR_STORE_PROVIDER=faiss
VECTOR_STORE_BASE_PATH=./vector_store
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4.1-mini
TONE_MODEL=gpt-4.1-mini
VISION_MODEL=gpt-4.1-mini
IMAGE_MODEL=gpt-image-1-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
RENDERER_FONT_PATH=./frontend/public/fonts/DM_Sans/static/DMSans-Regular.ttf
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_BATCH_SIZE=10
UPLOAD_MAX_FILE_BYTES=26214400
UPLOAD_MAX_PDF_PAGES=120
UPLOAD_MAX_PRESENTATION_PAGES=80
UPLOAD_MAX_IMAGE_MEGAPIXELS=36
OCR_RETRY_ATTEMPTS=3
OCR_RETRY_BACKOFF_SECONDS=1.5
